{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd sentinel/frontend && npm ci && cd ../.. && python3 -m pip install -r requirements.txt",
  "buildCommand": "cd sentinel/frontend && npm run build",
  "outputDirectory": "sentinel/frontend/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
